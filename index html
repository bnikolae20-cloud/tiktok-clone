<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TikTok Clone</title>

<style>
body {
    margin: 0;
    background: black;
    overflow-y: scroll;
    scroll-snap-type: y mandatory;
    font-family: Arial;
    color: white;
}

.video {
    height: 100vh;
    scroll-snap-align: start;
    position: relative;
}

video {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.right {
    position: absolute;
    right: 10px;
    bottom: 100px;
    text-align: center;
}

button {
    background: none;
    border: none;
    color: white;
    font-size: 20px;
    margin: 10px 0;
    cursor: pointer;
}
</style>
</head>

<body>

<input type="file" id="upload" style="position:fixed;top:10px;left:10px;z-index:999;">

<div id="feed"></div>

<script>
let videos = [
    {src:"https://www.w3schools.com/html/mov_bbb.mp4", likes:0},
    {src:"https://www.w3schools.com/html/movie.mp4", likes:0}
];

const feed = document.getElementById("feed");

// создать видео
function createVideo(v, i){
    const div = document.createElement("div");
    div.className = "video";

    div.innerHTML = `
        <video src="${v.src}" loop muted></video>
        <div class="right">
            <button onclick="like(${i}, this)">❤️ ${v.likes}</button>
        </div>
    `;

    feed.appendChild(div);
}

// лайк
function like(i, btn){
    videos[i].likes++;
    btn.innerText = "❤️ " + videos[i].likes;
}

// загрузка видео (локально)
document.getElementById("upload").onchange = e => {
    let file = e.target.files[0];
    if(file){
        let url = URL.createObjectURL(file);
        videos.push({src:url, likes:0});
        location.reload();
    }
};

// автоплей
function observe(){
    const vids = document.querySelectorAll("video");

    const obs = new IntersectionObserver(entries=>{
        entries.forEach(e=>{
            if(e.isIntersecting){
                e.target.play();
            } else {
                e.target.pause();
            }
        });
    },{threshold:0.7});

    vids.forEach(v=>obs.observe(v));
}

// запуск
videos.forEach((v,i)=>createVideo(v,i));
setTimeout(observe, 500);
</script>

</body>
</html>
